# syntax=docker/dockerfile:1
FROM rust:1.88-bookworm AS chef
RUN cargo install --locked cargo-chef
WORKDIR /app

FROM chef AS planner
COPY . .
RUN cargo chef prepare --recipe-path recipe.json

FROM chef AS builder
COPY --from=planner /app/recipe.json recipe.json
RUN cargo chef cook --release --recipe-path recipe.json -p rustclip-server
COPY . .
RUN cargo build --release -p rustclip-server

FROM gcr.io/distroless/cc-debian12:nonroot AS runtime
WORKDIR /app
COPY --from=builder /app/target/release/rustclip-server /app/rustclip-server
EXPOSE 8080
USER nonroot
ENTRYPOINT ["/app/rustclip-server"]
