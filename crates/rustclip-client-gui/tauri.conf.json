{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "RustClip",
  "version": "0.0.1",
  "identifier": "dev.rustclip.desktop",
  "build": {
    "frontendDist": "dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; img-src 'self' data:; connect-src ipc: http://ipc.localhost"
    },
    "macOSPrivateApi": false
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "macOS": {
      "exceptionDomain": "",
      "frameworks": []
    }
  }
}
