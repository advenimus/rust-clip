# Admin credentials used on first startup to create the admin user.
# Ignored on subsequent startups once the users table is populated.
RUSTCLIP_ADMIN_USERNAME=admin
RUSTCLIP_ADMIN_PASSWORD=please-change-me

# Public URL used in admin portal links and enrollment instructions.
RUSTCLIP_PUBLIC_URL=http://localhost:8080

# Maximum per-clip payload size in bytes. Default is 25 MB.
RUSTCLIP_MAX_PAYLOAD_BYTES=26214400

# How long encrypted blobs are queued server-side for offline devices.
RUSTCLIP_OFFLINE_TTL_HOURS=24

# tracing-subscriber env filter (e.g. info, debug, rustclip_server=debug).
RUSTCLIP_LOG_LEVEL=info

# Bind address for the server. Change if 8080 is taken on your host.
RUSTCLIP_BIND_ADDR=0.0.0.0:8080
